generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  nickname     String
  subjects     Subject[]
  tasks        StudyTask[]
  sessions     StudySession[]
  deviceTokens DeviceToken[]
  ownedMissionGroups MissionGroup[]       @relation("MissionGroupOwner")
  missionMemberships MissionGroupMember[]
  timeMissions MissionTimeRule[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Subject {
  id                  String         @id @default(cuid())
  userId              String
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  color               String
  targetMinutesPerDay Int            @default(60)
  tasks               StudyTask[]
  sessions            StudySession[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([userId])
}

model StudyTask {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title          String
  plannedDate    DateTime
  plannedMinutes Int
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, plannedDate])
}

model StudySession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId       String?
  subject         Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  startedAt       DateTime
  endedAt         DateTime
  durationMinutes Int
  note            String?
  createdAt       DateTime @default(now())

  @@index([userId, startedAt])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
}

model MissionGroup {
  id                  String               @id @default(cuid())
  ownerId             String
  owner               User                 @relation("MissionGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name                String
  inviteCode          String               @unique
  weeklyTargetMinutes Int                  @default(600)
  members             MissionGroupMember[]
  timeRules           MissionTimeRule[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([ownerId])
}

model MissionGroupMember {
  id        String       @id @default(cuid())
  groupId   String
  group     MissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String       @default("member")
  joinedAt  DateTime     @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model MissionTimeRule {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId         String?
  group           MissionGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title           String
  startMinute     Int
  endMinute       Int
  targetMinutes   Int           @default(60)
  reminderEnabled Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([groupId])
}
